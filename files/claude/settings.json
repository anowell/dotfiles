{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "Read",
      "Search",
      "Write",
      "WebFetch",
      "WebSearch",
      "Bash(temporal workflow show *)",
      "Bash(temporal workflow list *)",
      "mcp__*"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(rm -rf *)",
      "Read(./.env)",
      "Read(./.env.prod)",
      "Read(./secrets/**)",
      "Read(./secrets.*)",
      "Read(./**/*.pem)",
      "Read(./**/*id_rsa*)",
      "Read(./terraform/**/*.tfvars)",
      "Bash(su *)",
      "Bash(scp *)",
      "Bash(sftp *)",
      "Bash(rsync *)",
      "Bash(chown *)",
      "Bash(git)",
      "Bash(jj git push)",
      "Bash(jj git export)",
      "Bash(jj *--ignore-immutable*)",
      "Bash(bd sync *)",
      "Bash(bd delete *)",
      "Bash(fly deploy)",
      "Bash(fly machine)",
      "Bash(fly secrets)",
      "Bash(fly deploy)",
      "Bash(terraform apply)",
      "Bash(dd *)",
      "Bash(mkfs *)",
      "Bash(fdisk *)",
      "Bash(brew install *)",
      "Bash(pip install *)",
      "Bash(npm install -g *)",
      "Bash(launchctl)",
      "Bash(shutdown)",
      "Bash(reboot)",
      "Bash(printenv)",
      "Bash(env)",
      "Bash(export)"
    ],
    "ask": [
      "Bash(rm *)",
      "Bash(rmdir *)",
      "Bash(chmod *)",
      "Bash(jj git *)"
    ]
  },
  "env": {
    "RUNES_USER": "claude@agents.localhost"
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/claude-status.sh",
    "padding": 0
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-git.sh"
          }
        ]
      },
      {
        "matcher": "Bash|Read|Glob|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/block-env.sh"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754084947162
  }
}
